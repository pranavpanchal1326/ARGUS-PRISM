# ═══════════════════════════════════════
# ARGUS-PRISM | .env.example
# Engine: PRISM Core
# Branch: pranav/api
# ═══════════════════════════════════════
# Application name exposed by the API
APP_NAME=ARGUS-PRISM
# API version for health and metadata
VERSION=2.0.0
# Enable debug logging and development settings
DEBUG=true
# Postgres connection string for PRISM data
POSTGRES_URL=postgresql://prism:prism@localhost:5432/prismdb
# Redis host for cache and queues
REDIS_HOST=localhost
# Redis port for cache and queues
REDIS_PORT=6379
# Redis logical database index
REDIS_DB=0
# Neo4j bolt URI for graph intelligence
NEO4J_URI=bolt://localhost:7687
# Neo4j username for graph intelligence
NEO4J_USER=neo4j
# Neo4j password for graph intelligence
NEO4J_PASSWORD=prism1234
# DOT DIP base API URL for compliance checks
DOT_DIP_API_URL=https://dip.dot.gov.in/api/v1
# DOT DIP API key for compliance checks
DOT_DIP_API_KEY=your_api_key_here
# Minimum warmth score that triggers KYC review
WARMTH_KYC_THRESHOLD=60
# Minimum warmth score that triggers restriction
WARMTH_RESTRICT_THRESHOLD=75
# Minimum warmth score that triggers critical response
WARMTH_CRITICAL_THRESHOLD=85
# Minimum warmth score that triggers imminent response
WARMTH_IMMINENT_THRESHOLD=100
# Timeout for STR generation in seconds
STR_GENERATION_TIMEOUT_SECONDS=3600
# Maximum hop count for taint graph traversal
TAINT_MAX_HOPS=4
# Minimum accounts required to flag recruiter patterns
RECRUITER_MIN_ACCOUNTS=5
