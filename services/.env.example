# Application
APP_NAME=ARGUS-PRISM
APP_VERSION=2.0.0
ENVIRONMENT=development
DEBUG=false
LOG_LEVEL=INFO

# Database
DATABASE_URL=postgresql+asyncpg://prism:password@localhost:5432/prism_db
DATABASE_POOL_SIZE=10
DATABASE_MAX_OVERFLOW=20

# Redis
REDIS_URL=redis://localhost:6379/0
REDIS_WARMTH_TTL=300

# Aditya's Services (read-only for Pranav)
NEO4J_API_URL=http://localhost:8001
NEO4J_API_TIMEOUT=5

# Security
SECRET_KEY=change-this-to-32-char-minimum-random-string
API_KEY_HEADER=X-PRISM-API-Key

# PRISM Legal Thresholds (DO NOT CHANGE WITHOUT MLRO APPROVAL)
WARMTH_THRESHOLD_MONITORING=40.0
WARMTH_THRESHOLD_KYC=60.0
WARMTH_THRESHOLD_RESTRICTION=75.0
WARMTH_THRESHOLD_AUTOSTR=85.0
WARMTH_THRESHOLD_CBI=85.0
